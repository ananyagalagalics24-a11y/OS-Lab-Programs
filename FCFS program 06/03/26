#include<stdio.h>
#include <stdlib.h>

struct process{
    int at;
    int bt;
    int id;
    int ct;
    int tat;
    int wt;
};

int main()
{
    int n, i, j;
    float avgwt=0, avgtat=0;
    int curr=0;
    printf("Enter no. of process:");
    scanf("%d",&n);
    struct process p[n],temp;
    for(i=0;i<n;i++)
    {
        p[i].id=i+1;
        printf("Enter arrival time:");
        scanf("%d",&p[i].at);
        printf("Enter burst time:");
        scanf("%d",&p[i].bt);
    }
    for(i=0;i<n;i++)
    {
        for(j=i+1;j<n;j++)
        {
            if(p[i].at>p[j].at)
            {
                temp=p[i];
                p[i]=p[j];
                p[j]=temp;
            }
        }
    }
    for(i=0;i<n;i++)
    {
        if(curr<p[i].at)
        {
            curr=p[i].at;
        }
        p[i].ct=curr+p[i].bt;
        p[i].tat=p[i].ct-p[i].at;
        p[i].wt=p[i].tat-p[i].bt;
        curr=p[i].ct;
        avgwt+=p[i].wt;
        avgtat+=p[i].tat;
    }
    avgwt/=n;
    avgtat/=n;
    printf("\nID\tAT\tBT\tCT\tWT\tTAT\n");
    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",p[i].id,p[i].at,p[i].bt,p[i].ct,p[i].wt,p[i].tat);
    }
    printf("\nAverage TAT=%.2f",avgtat);
    printf("\nAverage WT=%.2f",avgwt);
    return 0;
}
